  "properties": {
    "run_dir": { "type": "string" },
    "ok": { "type": "boolean" },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "patch_gate": { "type": "object" },
    "trace_compact": { "type": "object" },
    "trace_report": { "type": "object" },
    "evidence_summary": { "type": "object" },
    "evidence_bundle_manifest": { "type": "object" },
    "evidence_verify_report": { "type": "object" }
  },
  "additionalProperties": false
}
