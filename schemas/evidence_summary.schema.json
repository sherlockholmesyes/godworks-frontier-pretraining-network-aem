{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AEM EvidenceSummary",
  "type": "object",
  "required": ["run_dir", "artifact_count", "missing_count", "missing", "artifacts"],
  "properties": {
    "run_dir": { "type": "string" },
    "artifact_count": { "type": "integer", "minimum": 0 },
    "missing_count": { "type": "integer", "minimum": 0 },
    "missing": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "exists", "size_bytes"],
        "properties": {
          "path": { "type": "string" },
          "exists": { "type": "boolean" },
          "size_bytes": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
