{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AEM DataShardManifest",
  "type": "object",
  "required": ["shard_id", "content_hash", "source_type", "license", "pii_status", "dedup_status"],
  "properties": {
    "shard_id": { "type": "string" },
    "content_hash": { "type": "string" },
    "source_type": { "type": "string" },
    "license": { "type": "string" },
    "pii_status": { "type": "string" },
    "dedup_status": { "type": "string" },
    "contamination_report_hash": { "type": "string" },
    "used_by_experts": { "type": "array", "items": { "type": "string" } },
    "eval_impact": { "type": "object", "additionalProperties": { "type": "number" } }
  },
  "additionalProperties": false
}
